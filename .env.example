# --- Telegram bot ---
BOT_TOKEN=
ADMINS_ID=[]

# --- Starknet RPC ---
# Full-node RPC endpoint (mainnet or sepolia).
# Public options: https://rpc.starknet.lava.build, https://starknet-mainnet.g.alchemy.com/v2/<KEY>
STARKNET_RPC_URL=https://rpc.starknet.lava.build
# Target network: mainnet | sepolia
STARKNET_NETWORK=mainnet

# --- REST API (FastAPI) ---
# Host/port for the API that serves the bot + Mini App + local dashboard.
API_HOST=127.0.0.1
# Host port for the dashboard / Mini App. 8765 is the default because 8000
# often clashes with other local stacks. Change freely.
API_PORT=8765
# Auth mode for API: telegram (HMAC initData), local (no auth, loopback only), both
API_AUTH_MODE=telegram
# Public HTTPS URL where the Mini App is served. Set to enable the
# "🖥 Dashboard" button in the bot's main menu. Telegram requires HTTPS;
# during local dev expose ${API_PORT} via ngrok / cloudflared and paste
# the resulting URL here. Leave blank to hide the button.
WEBAPP_URL=

# --- Production proxy (Caddy) ---
# Hostname Caddy issues a Let's Encrypt cert for. Must resolve via DNS to
# this server's public IP BEFORE you start the stack — otherwise the ACME
# challenge fails. In dev leave blank (Caddy responds with a placeholder).
DOMAIN=

# --- Feature flags ---
# Enable attestation monitoring (requires V2 contract, default on).
ATTESTATION_MONITOR_ENABLED=true
# Cache TTL for token metadata (seconds).
TOKEN_CACHE_TTL=3600
